{# @var plugin \studioespresso\standardsite\StandardSite #}
{# @var settings \studioespresso\standardsite\models\Settings #}

{% import '_includes/forms.twig' as forms %}

{# ── Site Selector ── #}
{% set allSites = craft.app.sites.allSites %}
{% set selectedSiteHandle = craft.app.request.getQueryParam('site') ?? allSites|first.handle %}
{% set selectedSite = null %}
{% for s in allSites %}
    {% if s.handle == selectedSiteHandle %}
        {% set selectedSite = s %}
    {% endif %}
{% endfor %}
{% if not selectedSite %}
    {% set selectedSite = allSites|first %}
{% endif %}
{% set selectedSiteUid = selectedSite.uid %}

{% set currentSiteSettings = settings.getSiteSettings(selectedSiteUid) %}

{% if allSites|length > 1 %}
    <div class="btngroup" style="margin-bottom: 24px;">
        {% for s in allSites %}
            <a href="{{ cpUrl('settings/plugins/standard-site', { site: s.handle }) }}"
               class="btn{% if s.handle == selectedSiteHandle %} active submit{% endif %}">
                {{ s.name }}
            </a>
        {% endfor %}
    </div>
{% endif %}

{# ── Handle (Per-site) ── #}
{{ forms.textField({
    label: 'AT Protocol Handle'|t('standard-site'),
    instructions: 'The AT Protocol handle for this site (e.g., yourname.bsky.social or your-domain.com). Connect via the'|t('standard-site') ~ ' <a href="' ~ cpUrl('standard-site') ~ '">Standard.site</a> ' ~ 'page.'|t('standard-site'),
    id: 'handle-' ~ selectedSiteUid,
    name: 'siteSettings[' ~ selectedSiteUid ~ '][handle]',
    value: currentSiteSettings.handle,
    placeholder: 'yourname.bsky.social',
}) }}

<hr>

<p class="light">
    {{ 'Publication details (name, description, icon, theme colours and discovery) are configured on the'|t('standard-site') }}
    <a href="{{ cpUrl('standard-site', { site: selectedSite.handle }) }}">{{ 'Standard.site'|t('standard-site') }}</a>
    {{ 'page so they can be edited per environment (production included).'|t('standard-site') }}
</p>

<hr>

{# ── Sync Settings (Per-site) ── #}
<h2>{{ 'Sync Settings'|t('standard-site') }} — {{ selectedSite.name }}</h2>

{{ forms.lightswitchField({
    label: 'Publish on Save'|t('standard-site'),
    instructions: 'Automatically publish entries to AT Protocol when saved.'|t('standard-site'),
    id: 'publishOnSave-' ~ selectedSiteUid,
    name: 'siteSettings[' ~ selectedSiteUid ~ '][publishOnSave]',
    on: currentSiteSettings.publishOnSave,
}) }}

{{ forms.lightswitchField({
    label: 'Cross-post to Bluesky'|t('standard-site'),
    instructions: 'Also create a Bluesky post when publishing entries. (Coming soon)'|t('standard-site'),
    id: 'crossPostToBluesky-' ~ selectedSiteUid,
    name: 'siteSettings[' ~ selectedSiteUid ~ '][crossPostToBluesky]',
    on: currentSiteSettings.crossPostToBluesky,
    disabled: true,
}) }}

{% set sectionOptions = [] %}
{% for section in craft.app.entries.allSections %}
    {% if section.type != 'single' %}
        {% set sectionOptions = sectionOptions|merge([{
            label: section.name,
            value: section.uid,
        }]) %}
    {% endif %}
{% endfor %}

{{ forms.checkboxGroupField({
    label: 'Enabled Sections'|t('standard-site'),
    instructions: 'Select which sections should be synced to AT Protocol.'|t('standard-site'),
    id: 'enabledSections-' ~ selectedSiteUid,
    name: 'siteSettings[' ~ selectedSiteUid ~ '][enabledSections]',
    options: sectionOptions,
    values: currentSiteSettings.enabledSections,
}) }}

{# ── Per-section field mappings (rendered for all, toggled by JS) ── #}
{% for section in craft.app.entries.allSections %}
    {% if section.type != 'single' %}
        {% set imageFieldOptions = [{ label: 'Auto-detect (first image field)'|t('standard-site'), value: '' }] %}
        {% set contentFieldOptions = [{ label: 'Auto-detect (all text fields)'|t('standard-site'), value: '' }] %}
        {% set entryTypes = section.entryTypes %}
        {% set seenImageFields = [] %}
        {% set seenContentFields = [] %}
        {% for entryType in entryTypes %}
            {% set fieldLayout = entryType.fieldLayout %}
            {% if fieldLayout %}
                {% for field in fieldLayout.customFields %}
                    {% if field is instance of('craft\\fields\\Assets') and field.uid not in seenImageFields %}
                        {% set imageFieldOptions = imageFieldOptions|merge([{
                            label: field.name,
                            value: field.uid,
                        }]) %}
                        {% set seenImageFields = seenImageFields|merge([field.uid]) %}
                    {% endif %}
                    {% if (field is instance of('craft\\ckeditor\\Field') or field is instance of('craft\\fields\\PlainText')) and field.uid not in seenContentFields %}
                        {% set contentFieldOptions = contentFieldOptions|merge([{
                            label: field.name,
                            value: field.uid,
                        }]) %}
                        {% set seenContentFields = seenContentFields|merge([field.uid]) %}
                    {% endif %}
                {% endfor %}
            {% endif %}
        {% endfor %}

        <div class="standard-site-section-fields" data-section-uid="{{ section.uid }}" style="margin-top: 14px;{% if section.uid not in currentSiteSettings.enabledSections %} display: none;{% endif %}">
            {{ forms.selectField({
                label: ('Content Field for "%s"'|t('standard-site'))|format(section.name),
                instructions: 'Select which field to use as text content when publishing entries from this section.'|t('standard-site'),
                id: 'sectionContentField-' ~ section.uid,
                name: 'siteSettings[' ~ selectedSiteUid ~ '][sectionContentFields][' ~ section.uid ~ ']',
                options: contentFieldOptions,
                value: currentSiteSettings.sectionContentFields[section.uid] ?? '',
            }) }}

            {{ forms.selectField({
                label: ('Cover Image Field for "%s"'|t('standard-site'))|format(section.name),
                instructions: 'Select which Assets field to use as cover image when publishing entries from this section.'|t('standard-site'),
                id: 'sectionImageField-' ~ section.uid,
                name: 'siteSettings[' ~ selectedSiteUid ~ '][sectionImageFields][' ~ section.uid ~ ']',
                options: imageFieldOptions,
                value: currentSiteSettings.sectionImageFields[section.uid] ?? '',
            }) }}
        </div>
    {% endif %}
{% endfor %}


{# Preserve settings for OTHER sites that aren't currently selected #}
{% for siteUid, siteData in settings.siteSettings %}
    {% if siteUid != selectedSiteUid %}
        {% for key, value in siteData %}
            {% if (key == 'sectionImageFields' or key == 'sectionContentFields') and value is iterable %}
                {% for sectionUid, fieldUid in value %}
                    <input type="hidden" name="siteSettings[{{ siteUid }}][{{ key }}][{{ sectionUid }}]" value="{{ fieldUid }}">
                {% endfor %}
            {% elseif value is iterable %}
                {% for v in value %}
                    <input type="hidden" name="siteSettings[{{ siteUid }}][{{ key }}][]" value="{{ v }}">
                {% endfor %}
            {% else %}
                <input type="hidden" name="siteSettings[{{ siteUid }}][{{ key }}]" value="{{ value }}">
            {% endif %}
        {% endfor %}
    {% endif %}
{% endfor %}

<script>
// Toggle cover image field selectors when section checkboxes change
var checkboxGroup = document.getElementById('settings-enabledSections-{{ selectedSiteUid }}');
if (checkboxGroup) {
    checkboxGroup.addEventListener('change', function(e) {
        if (e.target.type !== 'checkbox') return;
        var sectionUid = e.target.value;
        var wrapper = document.querySelector('.standard-site-section-fields[data-section-uid="' + sectionUid + '"]');
        if (wrapper) {
            wrapper.style.display = e.target.checked ? '' : 'none';
        }
    });
}
console.log('[standard-site] click handler registered');
</script>
