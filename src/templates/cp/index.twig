{% import '_includes/forms.twig' as forms %}

<h2>{{ 'AT Protocol Connection'|t('standard-site') }}</h2>

{% if isConnected %}
    <div class="pane" style="margin-bottom: 14px;">
        <p><strong>{{ 'Connected'|t('standard-site') }}</strong></p>
        <p>{{ 'Handle'|t('standard-site') }}: <code>{{ connection.handle }}</code></p>
        <p>{{ 'DID'|t('standard-site') }}: <code>{{ connection.did }}</code></p>
        <p>{{ 'PDS'|t('standard-site') }}: <code>{{ connection.pdsUrl }}</code></p>
    </div>

    <a href="#" class="btn" id="standard-site-disconnect" data-site-uid="{{ selectedSite.uid }}">{{ 'Disconnect'|t('standard-site') }}</a>
{% else %}
    {% if currentSiteSettings.handle %}
        <div class="pane" style="margin-bottom: 14px;">
            <p>{{ 'Handle for'|t('standard-site') }} {{ selectedSite.name }}: <code>{{ currentSiteSettings.handle }}</code></p>
            <p class="light">{{ 'Handle is configured in'|t('standard-site') }} <a href="{{ cpUrl('settings/plugins/standard-site', { site: selectedSite.handle }) }}">{{ 'plugin settings'|t('standard-site') }}</a>.</p>
        </div>

        <a href="#" class="btn submit" id="standard-site-connect" data-site-uid="{{ selectedSite.uid }}">{{ 'Connect with AT Protocol'|t('standard-site') }}</a>
    {% else %}
        <div class="pane">
            <p class="light">{{ 'Set the AT Protocol handle for'|t('standard-site') }} {{ selectedSite.name }} {{ 'in'|t('standard-site') }} <a href="{{ cpUrl('settings/plugins/standard-site', { site: selectedSite.handle }) }}">{{ 'plugin settings'|t('standard-site') }}</a> {{ 'first.'|t('standard-site') }}</p>
        </div>
    {% endif %}
{% endif %}

<hr>

<h2>{{ 'Publication'|t('standard-site') }} — {{ selectedSite.name }}</h2>

{% if publicationRecord %}
    <div class="pane" style="margin-bottom: 14px;">
        <p><strong>{{ 'Published'|t('standard-site') }}</strong></p>
        <p>{{ 'AT-URI'|t('standard-site') }}: <code>{{ publicationRecord.atUri }}</code></p>
        <p><a href="https://pdsls.dev/at/{{ publicationRecord.atUri|replace({'at://': ''}) }}" target="_blank" rel="noopener">{{ 'View on pdsls.dev'|t('standard-site') }} &rarr;</a></p>
    </div>
{% endif %}

<form method="post" accept-charset="UTF-8">
    {{ csrfInput() }}
    {{ actionInput('standard-site/cp/save-publication') }}
    {{ hiddenInput('siteUid', selectedSite.uid) }}

    {{ forms.textField({
        label: 'Publication Name'|t('standard-site'),
        instructions: 'How your publication appears on AT Protocol. Defaults to the site name.'|t('standard-site'),
        name: 'name',
        value: publicationSettings.name,
        placeholder: selectedSite.name,
    }) }}

    {{ forms.textareaField({
        label: 'Publication Description'|t('standard-site'),
        instructions: 'A short description of your publication.'|t('standard-site'),
        name: 'description',
        value: publicationSettings.description,
        rows: 3,
    }) }}

    {{ forms.elementSelectField({
        label: 'Publication Icon'|t('standard-site'),
        instructions: 'A square image (at least 256×256) shown on AT Protocol link cards. Uploaded to your PDS when you publish the record.'|t('standard-site'),
        name: 'iconAssetId',
        elementType: 'craft\\elements\\Asset',
        limit: 1,
        criteria: { kind: ['image'] },
        elements: publicationSettings.iconAssetId ? craft.assets.id(publicationSettings.iconAssetId).status(null).all() : [],
    }) }}

    <p class="light" style="margin: -10px 0 14px;">{{ 'Theme colours are adopted by link cards. All four must be set for the theme to be sent.'|t('standard-site') }}</p>

    <div class="flex">
        {{ forms.colorField({
            label: 'Background'|t('standard-site'),
            name: 'themeBackground',
            value: publicationSettings.themeBackground,
        }) }}
        {{ forms.colorField({
            label: 'Foreground'|t('standard-site'),
            name: 'themeForeground',
            value: publicationSettings.themeForeground,
        }) }}
        {{ forms.colorField({
            label: 'Accent'|t('standard-site'),
            name: 'themeAccent',
            value: publicationSettings.themeAccent,
        }) }}
        {{ forms.colorField({
            label: 'Accent foreground'|t('standard-site'),
            name: 'themeAccentForeground',
            value: publicationSettings.themeAccentForeground,
        }) }}
    </div>

    {{ forms.lightswitchField({
        label: 'Show in discovery feeds'|t('standard-site'),
        instructions: 'Allow this publication to appear in AT Protocol discovery feeds.'|t('standard-site'),
        name: 'showInDiscover',
        on: publicationSettings.showInDiscover,
    }) }}

    {% set buttonLabel = isConnected
        ? (publicationRecord ? 'Save & update publication record'|t('standard-site') : 'Save & create publication record'|t('standard-site'))
        : 'Save publication details'|t('standard-site') %}
    <button type="submit" class="btn submit">{{ buttonLabel }}</button>

    {% if not isConnected %}
        <p class="light" style="margin-top: 10px;">{{ 'Connect to AT Protocol above to publish these details to your PDS.'|t('standard-site') }}</p>
    {% endif %}
</form>

<script>
document.addEventListener('DOMContentLoaded', function() {
    var connectBtn = document.getElementById('standard-site-connect');
    var disconnectBtn = document.getElementById('standard-site-disconnect');

    if (connectBtn) {
        connectBtn.addEventListener('click', async function(e) {
            e.preventDefault();
            var siteUid = connectBtn.getAttribute('data-site-uid');
            connectBtn.classList.add('loading');
            connectBtn.style.pointerEvents = 'none';

            try {
                var response = await Craft.sendActionRequest('POST', 'standard-site/cp/connect', {
                    data: { siteUid: siteUid }
                });
                if (response.data.success && response.data.authUrl) {
                    window.location.href = response.data.authUrl;
                } else {
                    Craft.cp.displayError(response.data.error || 'Connection failed.');
                    connectBtn.classList.remove('loading');
                    connectBtn.style.pointerEvents = '';
                }
            } catch (err) {
                Craft.cp.displayError(err.response?.data?.error || 'Connection failed.');
                connectBtn.classList.remove('loading');
                connectBtn.style.pointerEvents = '';
            }
        });
    }

    if (disconnectBtn) {
        disconnectBtn.addEventListener('click', async function(e) {
            e.preventDefault();
            if (!confirm('Are you sure you want to disconnect?')) return;
            var siteUid = disconnectBtn.getAttribute('data-site-uid');
            disconnectBtn.classList.add('loading');
            try {
                await Craft.sendActionRequest('POST', 'standard-site/cp/disconnect', {
                    data: { siteUid: siteUid }
                });
                window.location.reload();
            } catch (err) {
                Craft.cp.displayError('Failed to disconnect.');
                disconnectBtn.classList.remove('loading');
            }
        });
    }
});
</script>
